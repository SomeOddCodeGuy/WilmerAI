      "type": "CustomWorkflow",
      "workflowName": "General_With_Vision_DiscussionId_CoT",
      "workflowUserFolderOverride": "_common",
      "scoped_variables": [
        "{VisionModel}",
        "{VisionPreset}",
        "{VisionRespondTokenSize}",
        "{MinMessagesToSendVisionLLM}",
        "{MaxTokensToSendVisionLLM}",
        "{ThinkingModel}",
        "{ThinkingPreset}",
        "{ThinkingResponseTokenSize}",
        "{MinMessagesToSendThinkingLLM}",
        "{MaxTokensToSendThinkingLLM}",
        "{RespondingModel}",
        "{RespondingPreset}",
        "{RespondingResponseTokenSize}",
        "{MinMessagesToSendRespondingLLM}",
        "{MaxTokensToSendRespondingLLM}"
      ]
    }
  ]
}
