  "VisionRespondTokenSize": 6000,
  "MinMessagesToSendVisionLLM": 10,
  "MaxTokensToSendVisionLLM": 8000,
  "ThinkingModel": "General-Endpoint",
  "ThinkingPreset": "General-Endpoint",
  "ThinkingResponseTokenSize": 12000,
  "MinMessagesToSendThinkingLLM": 10,
  "MaxTokensToSendThinkingLLM": 15000,
  "RespondingModel": "General-Endpoint",
  "RespondingPreset": "General-Endpoint",
  "RespondingResponseTokenSize": 8000,
  "MinMessagesToSendRespondingLLM": 10,
  "MaxTokensToSendRespondingLLM": 15000,
  "nodes": [
    {
      "displayOnlyComment": "Meant for your best general llm. This workflow has a manual chain of thought step for models that lack reasoning, or have broken reasoning. Separate vision node works well with discussion id to avoid re-processing images",
