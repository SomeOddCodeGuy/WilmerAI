{
  "modelNameForDisplayOnly": "Llama.Cpp Example Endpoint (with embedded canonical samplers)",
  "endpoint": "http://192.168.1.100:5001",
  "apiTypeConfigFileName": "LlamaCppServer",
  "maxContextTokenSize": 65535,
  "modelNameToSendToAPI": "None",
  "promptTemplate": "chatml",
  "addGenerationPrompt": true,
  "trimBeginningAndEndLineBreaks": true,
  "dontIncludeModel": true,
  "presetSamplers": {
    "temperature": 0.8,
    "dynatemp_range": 0.0,
    "dynatemp_exponent": 1.0,
    "top_k": 40,
    "top_p": 0.95,
    "min_p": 0.05,
    "top_n_sigma": -1.0,
    "typical_p": 1.0,
    "repeat_penalty": 1.0,
    "repeat_last_n": 64,
    "presence_penalty": 0.0,
    "frequency_penalty": 0.0,
    "dry_multiplier": 0.0,
    "dry_base": 1.75,
    "dry_allowed_length": 2,
    "dry_penalty_last_n": -1,
    "dry_sequence_breakers": ["\n", ":", "\"", "*"],
    "xtc_probability": 0.0,
    "xtc_threshold": 0.1,
    "mirostat": 0,
    "mirostat_tau": 5.0,
    "mirostat_eta": 0.1,
    "seed": -1,
    "stop": ["<|im_end|>"],
    "samplers": ["dry", "top_n_sigma", "top_k", "typ_p", "top_p", "min_p", "xtc", "temperature"],
    "logit_bias": [],
    "ignore_eos": false,
    "n_probs": 0,
    "min_keep": 0,
    "grammar": "",
    "json_schema": null,
    "thinkingMode": "off",
    "chat_template_kwargs": {
      "thinking_budget": 0
    }
  }
}
